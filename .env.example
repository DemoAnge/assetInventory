# ─── Django ───────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Base de datos MySQL ───────────────────────────────
DB_NAME=inventario_activos
DB_USER=root
DB_PASSWORD=your_password
DB_HOST=127.0.0.1
DB_PORT=3306

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Cifrado AES-256 (django-encrypted-model-fields) ──
FIELD_ENCRYPTION_KEY=your-32-byte-base64-key-here

# ─── MFA ──────────────────────────────────────────────
MFA_ISSUER_NAME=

# ─── CORS ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Node.js Security Agent ───────────────────────────
NODE_PORT=4000
NODE_URL=http://localhost:4000
NODE_JWT_SECRET=same-as-django-jwt-secret


